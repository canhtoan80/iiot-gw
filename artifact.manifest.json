{
  "project": "EMS IIoT Gateway (Tier 2A)",
  "version": "1.2.0-stable",
  "build_info": {
    "runtime": ".NET 8.0",
    "target_platforms": ["linux-x64", "linux-arm64"],
    "configurations": ["Debug", "Release"],
    "packaging": ".deb"
  },
  "artifacts": [
    {
      "name": "ems-gateway",
      "type": "executable",
      "path": "/usr/bin/ems-gateway",
      "description": "Main gateway firmware service (Self-contained binary)."
    },
    {
      "name": "buffer.db",
      "type": "database",
      "path": "/var/lib/ems-gateway/buffer.db",
      "description": "SQLite storage for local data buffering (72h retention)."
    },
    {
      "name": "appsettings.json",
      "type": "configuration",
      "path": "/etc/ems-gateway/appsettings.json",
      "description": "Global gateway configuration."
    },
    {
      "name": "devices.json",
      "type": "configuration",
      "path": "/etc/ems-gateway/devices.json",
      "description": "Modbus/BACnet device templates and register definitions."
    }
  ],
  "dependencies": {
    "system": [
      "mosquitto",
      "sqlite3",
      "chrony",
      "modemmanager",
      "wireguard",
      "usbipd-win (dev-only)"
    ],
    "nuget": [
      "MQTTnet",
      "Eclipse.Tahu.Protobuf",
      "NCalc2",
      "FluentModbus",
      "Microsoft.Data.Sqlite"
    ]
  },
  "deployment": {
    "method": "systemd",
    "services": ["ems-gateway.service", "mosquitto.service", "emqx.service (G1/G2)"],
    "mounts": [
      {
        "type": "tmpfs",
        "path": "/dev/shm/ems-buffer",
        "size": "256M"
      }
    ],
    "ports": {
      "mosquitto": 1883,
      "emqx_internal": 1884,
      "emqx_external": 8883,
      "admin_ui": 8080,
      "prometheus": 9090
    }
  }
}
